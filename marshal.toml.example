# marshal.toml — project-local configuration
# Copy to marshal.toml and fill in your API keys.
# Secrets can be passed as environment variables using ${VAR_NAME} syntax.

[model.marshal]
provider = "fireworks"
model    = "accounts/fireworks/models/qwen3-235b-a22b"
api_key  = "${FIREWORKS_API_KEY}"
base_url = "https://api.fireworks.ai/inference/v1"

[model.executor]
provider = "fireworks"
model    = "accounts/fireworks/models/qwen3-235b-a22b"
api_key  = "${FIREWORKS_API_KEY}"
base_url = "https://api.fireworks.ai/inference/v1"

[model.critic]
provider = "fireworks"
model    = "accounts/fireworks/models/qwen3-235b-a22b"
api_key  = "${FIREWORKS_API_KEY}"
base_url = "https://api.fireworks.ai/inference/v1"

[model.compactor]
provider = "fireworks"
model    = "accounts/fireworks/models/qwen3-235b-a22b"
api_key  = "${FIREWORKS_API_KEY}"
base_url = "https://api.fireworks.ai/inference/v1"

[loop]
max_rounds    = 3
compact_after = 2
clarify       = "ambiguous"   # "never" | "ambiguous" | "always"

[linters]
go     = "golangci-lint run"
python = "flake8"
js     = "eslint"
ts     = "eslint"

# ── Profiles ──────────────────────────────────────────────────────────────────
# Use: marshal --profile dev config show
# Only fields set here override the base config; everything else falls through.

[profiles.dev.model.marshal]
provider = "ollama"
model    = "qwen3:8b"
base_url = "http://localhost:11434/v1"
api_key  = "ollama"

[profiles.dev.model.executor]
provider = "ollama"
model    = "qwen3:8b"
base_url = "http://localhost:11434/v1"
api_key  = "ollama"

[profiles.dev.model.critic]
provider = "ollama"
model    = "qwen3:8b"
base_url = "http://localhost:11434/v1"
api_key  = "ollama"

[profiles.dev.model.compactor]
provider = "ollama"
model    = "qwen3:1.7b"
base_url = "http://localhost:11434/v1"
api_key  = "ollama"
